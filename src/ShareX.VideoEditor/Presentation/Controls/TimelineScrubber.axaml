<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="ShareX.VideoEditor.Presentation.Controls.TimelineScrubber"
             d:DesignWidth="800" d:DesignHeight="80"
             MinHeight="60">

  <!-- The timeline scrubber is rendered primarily in code-behind via a Canvas overlay.
       The AXAML provides the structural skeleton and static background layers. -->
  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Row 0: time ruler (drawn in code-behind) -->
    <Canvas Grid.Row="0" Name="RulerCanvas" Height="16" ClipToBounds="True" />

    <!-- Row 1: thumbnail track + overlays -->
    <Grid Grid.Row="1">
      <!-- Thumbnail strip -->
      <ItemsControl Name="ThumbnailStrip"
                    ItemsSource="{Binding Thumbnails, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Horizontal" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Image Source="{Binding}"
                   Stretch="UniformToFill"
                   Width="48"
                   Height="36" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Empty track background (shown when no thumbnails) -->
      <Border Name="EmptyTrack"
              Background="#0D0D16"
              IsHitTestVisible="False" />

      <!-- Trim region highlight overlay -->
      <Canvas Name="TrimRegionCanvas"
              IsHitTestVisible="False"
              ClipToBounds="True">
        <!-- Trim region drawn in code-behind -->
        <Border Name="TrimRegionFill"
                Background="#2800C8F0"
                IsHitTestVisible="False" />
        <!-- Left trim handle -->
        <Border Name="TrimStartHandle"
                Width="6"
                CornerRadius="3 0 0 3"
                Background="#FF00C8F0"
                Cursor="SizeWestEast"
                IsHitTestVisible="True" />
        <!-- Right trim handle -->
        <Border Name="TrimEndHandle"
                Width="6"
                CornerRadius="0 3 3 0"
                Background="#FF00C8F0"
                Cursor="SizeWestEast"
                IsHitTestVisible="True" />
        <!-- Playhead -->
        <Border Name="Playhead"
                Width="2"
                Background="#FFFF4757"
                IsHitTestVisible="False" />
        <!-- Playhead head diamond -->
        <Border Name="PlayheadHead"
                Width="10" Height="10"
                CornerRadius="2"
                Background="#FFFF4757"
                IsHitTestVisible="False"
                RenderTransformOrigin="0.5,0.5">
          <Border.RenderTransform>
            <RotateTransform Angle="45" />
          </Border.RenderTransform>
        </Border>
      </Canvas>
    </Grid>

    <!-- Row 2: minor time markers -->
    <Canvas Grid.Row="2" Name="MarkersCanvas" Height="14" ClipToBounds="True" />
  </Grid>
</UserControl>
