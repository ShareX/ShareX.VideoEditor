<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ShareX.VideoEditor.Presentation.ViewModels"
        xmlns:controls="using:ShareX.VideoEditor.Presentation.Controls"
        mc:Ignorable="d"
        x:Class="ShareX.VideoEditor.Presentation.Views.VideoEditorWindow"
        x:CompileBindings="True"
        x:DataType="vm:VideoEditorViewModel"
        d:DesignWidth="1280" d:DesignHeight="800"
        MinWidth="900" MinHeight="600"
        Title="{Binding WindowTitle}"
        WindowStartupLocation="CenterScreen"
        Width="1280" Height="800"
        Background="{StaticResource VE_Base}">

  <Window.Styles>
    <StyleInclude Source="avares://ShareX.VideoEditor/Presentation/Resources/VideoEditorResources.axaml" />
  </Window.Styles>

  <!-- Root layout: Header | Player | Transport | Timeline+Tools -->
  <Grid RowDefinitions="48,*,64,240">

    <!-- ══════════════════════════════════════════════
         ROW 0 — HEADER BAR
         ══════════════════════════════════════════════ -->
    <Border Grid.Row="0"
            Background="{StaticResource VE_Surface}"
            BorderBrush="{StaticResource VE_Border}"
            BorderThickness="0 0 0 1">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="12 0">

        <!-- Left: Logo + Title -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Border Width="28" Height="28"
                  Background="{StaticResource VE_Accent}"
                  CornerRadius="6">
            <TextBlock Text="▶"
                       FontSize="12"
                       Foreground="{StaticResource VE_Base}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="VIDEO EDITOR"
                     FontFamily="{StaticResource VE_FontUI}"
                     FontSize="{StaticResource VE_FontSM}"
                     FontWeight="SemiBold"
                     LetterSpacing="1.5"
                     Foreground="{StaticResource VE_Text}"
                     VerticalAlignment="Center" />
          <Border Width="1" Height="18" Background="{StaticResource VE_Border}" Margin="4 0" />
          <TextBlock Text="{Binding VideoPath}"
                     FontFamily="{StaticResource VE_FontMono}"
                     FontSize="{StaticResource VE_FontXS}"
                     Foreground="{StaticResource VE_TextSecondary}"
                     TextTrimming="LeadingCharacterEllipsis"
                     MaxWidth="320"
                     VerticalAlignment="Center" />
        </StackPanel>

        <!-- Center: export progress indicator -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="6"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsExporting}">
          <TextBlock Text="{Binding ExportStatusMessage}"
                     FontFamily="{StaticResource VE_FontUI}"
                     FontSize="{StaticResource VE_FontSM}"
                     Foreground="{StaticResource VE_Accent}" />
          <ProgressBar Value="{Binding ExportProgress}"
                       Minimum="0" Maximum="100"
                       Width="120" Height="4"
                       CornerRadius="2"
                       Foreground="{StaticResource VE_Accent}"
                       Background="{StaticResource VE_Border}" />
        </StackPanel>

        <!-- Right: Export shortcut -->
        <Button Grid.Column="2"
                Classes="ve-primary"
                Content="Export"
                Command="{Binding ExportCommand}"
                IsEnabled="{Binding !IsExporting}"
                ToolTip.Tip="Export video (Ctrl+E)"
                HotKey="Ctrl+E" />
      </Grid>
    </Border>

    <!-- ══════════════════════════════════════════════
         ROW 1 — VIDEO PLAYER
         ══════════════════════════════════════════════ -->
    <Border Grid.Row="1"
            Background="#FF050508"
            Name="PlayerContainer">
      <Grid>
        <!-- Video surface (media player control placed here in code-behind) -->
        <ContentControl Name="VideoSurface"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch" />

        <!-- Placeholder before media loads -->
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12"
                    IsVisible="{Binding !IsMediaLoaded}">
          <Border Width="64" Height="64"
                  CornerRadius="32"
                  Background="{StaticResource VE_SurfaceElevated}">
            <TextBlock Text="▶"
                       FontSize="24"
                       Foreground="{StaticResource VE_TextSecondary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="Loading video…"
                     FontFamily="{StaticResource VE_FontUI}"
                     FontSize="{StaticResource VE_FontLG}"
                     Foreground="{StaticResource VE_TextSecondary}"
                     HorizontalAlignment="Center" />
          <TextBlock Text="{Binding VideoPath}"
                     FontFamily="{StaticResource VE_FontMono}"
                     FontSize="{StaticResource VE_FontXS}"
                     Foreground="{StaticResource VE_TextMuted}"
                     HorizontalAlignment="Center"
                     TextTrimming="LeadingCharacterEllipsis"
                     MaxWidth="400" />
        </StackPanel>

        <!-- Crop overlay -->
        <Canvas Name="CropOverlay"
                IsVisible="{Binding IsCropMode}"
                Background="#60000000">
          <Border Name="CropRect"
                  BorderBrush="{StaticResource VE_Accent}"
                  BorderThickness="2"
                  Background="#20FFFFFF"
                  IsVisible="{Binding IsCropActive}" />
        </Canvas>

        <!-- Export progress overlay -->
        <Grid IsVisible="{Binding IsExporting}"
              Background="#B0050508">
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="20"
                      MaxWidth="320">
            <TextBlock Text="Exporting…"
                       FontFamily="{StaticResource VE_FontUI}"
                       FontSize="{StaticResource VE_FontDisplay}"
                       FontWeight="Bold"
                       Foreground="{StaticResource VE_Text}"
                       HorizontalAlignment="Center" />
            <ProgressBar Value="{Binding ExportProgress}"
                         Minimum="0" Maximum="100"
                         Height="6"
                         CornerRadius="3"
                         Foreground="{StaticResource VE_Accent}"
                         Background="{StaticResource VE_Border}" />
            <TextBlock Text="{Binding ExportStatusMessage}"
                       FontFamily="{StaticResource VE_FontUI}"
                       FontSize="{StaticResource VE_FontMD}"
                       Foreground="{StaticResource VE_TextSecondary}"
                       HorizontalAlignment="Center" />
            <Button Classes="ve-ghost"
                    Content="Cancel"
                    Command="{Binding CancelExportCommand}"
                    HorizontalAlignment="Center" />
          </StackPanel>
        </Grid>
      </Grid>
    </Border>

    <!-- ══════════════════════════════════════════════
         ROW 2 — TRANSPORT CONTROLS
         ══════════════════════════════════════════════ -->
    <Border Grid.Row="2"
            Background="{StaticResource VE_Surface}"
            BorderBrush="{StaticResource VE_Border}"
            BorderThickness="0 1 0 1">
      <Grid ColumnDefinitions="*,Auto,*" Margin="16 0">

        <!-- Left: position / duration -->
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">
          <TextBlock Classes="ve-timecode" Text="{Binding PositionDisplay}" />
          <TextBlock Classes="ve-timecode"
                     Text=" / "
                     Foreground="{StaticResource VE_TextMuted}" />
          <TextBlock Classes="ve-timecode"
                     Text="{Binding DurationDisplay}"
                     Foreground="{StaticResource VE_TextSecondary}" />
        </StackPanel>

        <!-- Center: transport buttons -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">
          <Button Classes="ve-transport"
                  Command="{Binding SkipBackCommand}"
                  ToolTip.Tip="Skip back 5s (Left)">
            <TextBlock Text="⏮" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Button>

          <Button Classes="ve-play"
                  Command="{Binding PlayPauseCommand}"
                  ToolTip.Tip="Play / Pause (Space)">
            <TextBlock Text="{Binding PlayPauseGlyph}"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Button>

          <Button Classes="ve-transport"
                  Command="{Binding SkipForwardCommand}"
                  ToolTip.Tip="Skip forward 5s (Right)">
            <TextBlock Text="⏭" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Button>
        </StackPanel>

        <!-- Right: volume -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right">
          <TextBlock Text="🔊"
                     FontSize="14"
                     Foreground="{StaticResource VE_TextSecondary}"
                     VerticalAlignment="Center" />
          <Slider Classes="ve-slider"
                  Value="{Binding Volume}"
                  Minimum="0" Maximum="1"
                  Width="80"
                  ToolTip.Tip="Volume" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- ══════════════════════════════════════════════
         ROW 3 — TIMELINE + TOOLS PANEL
         ══════════════════════════════════════════════ -->
    <Grid Grid.Row="3" ColumnDefinitions="*,1,300">

      <!-- Timeline area -->
      <Border Grid.Column="0"
              Background="{StaticResource VE_TimelineTrack}"
              Padding="16 12">
        <Grid RowDefinitions="*,Auto">

          <!-- Custom timeline scrubber control -->
          <controls:TimelineScrubber
            Grid.Row="0"
            Duration="{Binding Duration}"
            Position="{Binding Position}"
            TrimStart="{Binding TrimStart}"
            TrimEnd="{Binding TrimEnd}"
            Thumbnails="{Binding TimelineThumbnails}"
            Name="TimelineScrubberControl" />

          <!-- Timeline footer -->
          <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="0 8 0 0">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Classes="ve-section-header" Text="IN" VerticalAlignment="Center" />
                <TextBlock Classes="ve-timecode"
                           Text="{Binding TrimStartDisplay}"
                           FontSize="{StaticResource VE_FontSM}"
                           Foreground="{StaticResource VE_Accent}" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Classes="ve-section-header" Text="OUT" VerticalAlignment="Center" />
                <TextBlock Classes="ve-timecode"
                           Text="{Binding TrimEndDisplay}"
                           FontSize="{StaticResource VE_FontSM}"
                           Foreground="{StaticResource VE_Accent}" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Classes="ve-section-header" Text="DUR" VerticalAlignment="Center" />
                <TextBlock Classes="ve-timecode"
                           Text="{Binding TrimDurationDisplay}"
                           FontSize="{StaticResource VE_FontSM}"
                           Foreground="{StaticResource VE_TextSecondary}" />
              </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="6"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsThumbnailsLoading}">
              <TextBlock Text="Generating thumbnails…"
                         FontFamily="{StaticResource VE_FontUI}"
                         FontSize="{StaticResource VE_FontXS}"
                         Foreground="{StaticResource VE_TextMuted}" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
              <Button Classes="ve-ghost"
                      Content="[ Set In"
                      Command="{Binding SetTrimStartCommand}"
                      FontFamily="{StaticResource VE_FontMono}"
                      FontSize="{StaticResource VE_FontXS}"
                      ToolTip.Tip="Set trim in point (I)" />
              <Button Classes="ve-ghost"
                      Content="Set Out ]"
                      Command="{Binding SetTrimEndCommand}"
                      FontFamily="{StaticResource VE_FontMono}"
                      FontSize="{StaticResource VE_FontXS}"
                      ToolTip.Tip="Set trim out point (O)" />
              <Button Classes="ve-ghost"
                      Content="Reset"
                      Command="{Binding ResetTrimCommand}"
                      FontSize="{StaticResource VE_FontXS}"
                      IsVisible="{Binding IsTrimActive}"
                      ToolTip.Tip="Reset trim to full duration" />
            </StackPanel>
          </Grid>
        </Grid>
      </Border>

      <!-- Vertical separator -->
      <Border Grid.Column="1" Classes="ve-vseparator" />

      <!-- ── TOOLS PANEL ── -->
      <Border Grid.Column="2"
              Background="{StaticResource VE_Surface}">
        <Grid RowDefinitions="Auto,*,Auto">

          <!-- Tab bar -->
          <Border Grid.Row="0"
                  BorderBrush="{StaticResource VE_Border}"
                  BorderThickness="0 0 0 1"
                  Padding="8 6">
            <StackPanel Orientation="Horizontal" Spacing="2">
              <Button Classes="ve-tab" Content="Trim" Command="{Binding SelectTrimPanelCommand}" />
              <Button Classes="ve-tab" Content="Crop" Command="{Binding SelectCropPanelCommand}" />
              <Button Classes="ve-tab" Content="Watermark" Command="{Binding SelectWatermarkPanelCommand}" />
              <Button Classes="ve-tab" Content="Export" Command="{Binding SelectExportPanelCommand}" />
            </StackPanel>
          </Border>

          <!-- Panel content -->
          <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16 12" Spacing="16">

              <!-- TRIM PANEL -->
              <StackPanel Spacing="12"
                          IsVisible="{Binding ActivePanel, Converter={x:Static vm:ToolPanelConverters.IsTrim}}">
                <TextBlock Classes="ve-section-header" Text="TRIM" />
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                  <TextBlock Grid.Row="0" Grid.Column="0" Classes="ve-label" Text="In" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="0" Grid.Column="1"
                             Classes="ve-timecode"
                             Text="{Binding TrimStartDisplay}"
                             FontSize="{StaticResource VE_FontSM}"
                             Foreground="{StaticResource VE_Accent}" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Classes="ve-label" Text="Out" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="1" Grid.Column="1"
                             Classes="ve-timecode"
                             Text="{Binding TrimEndDisplay}"
                             FontSize="{StaticResource VE_FontSM}"
                             Foreground="{StaticResource VE_Accent}" />
                  <TextBlock Grid.Row="2" Grid.Column="0" Classes="ve-label" Text="Duration" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="2" Grid.Column="1"
                             Classes="ve-timecode"
                             Text="{Binding TrimDurationDisplay}"
                             FontSize="{StaticResource VE_FontSM}" />
                </Grid>
                <Border Classes="ve-separator" />
                <TextBlock Classes="ve-label"
                           Text="Drag trim handles on the timeline, or use [ Set In ] / [ Set Out ]."
                           TextWrapping="Wrap" />
              </StackPanel>

              <!-- CROP PANEL -->
              <StackPanel Spacing="12"
                          IsVisible="{Binding ActivePanel, Converter={x:Static vm:ToolPanelConverters.IsCrop}}">
                <TextBlock Classes="ve-section-header" Text="CROP" />
                <Button Classes="ve-primary"
                        Content="{Binding IsCropMode, Converter={x:Static vm:ToolPanelConverters.CropModeLabel}}"
                        Command="{Binding ToggleCropModeCommand}"
                        HorizontalAlignment="Stretch" />
                <TextBlock Classes="ve-label"
                           Text="Enable crop mode, then drag the crop region on the video."
                           TextWrapping="Wrap" />
                <Grid ColumnDefinitions="Auto,*"
                      RowDefinitions="Auto,Auto,Auto,Auto"
                      RowSpacing="8" ColumnSpacing="8"
                      IsVisible="{Binding IsCropActive}">
                  <TextBlock Grid.Row="0" Grid.Column="0" Classes="ve-label" Text="X" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="0" Grid.Column="1" Classes="ve-body" Text="{Binding CropX}" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Classes="ve-label" Text="Y" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="1" Grid.Column="1" Classes="ve-body" Text="{Binding CropY}" />
                  <TextBlock Grid.Row="2" Grid.Column="0" Classes="ve-label" Text="W" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="2" Grid.Column="1" Classes="ve-body" Text="{Binding CropWidth}" />
                  <TextBlock Grid.Row="3" Grid.Column="0" Classes="ve-label" Text="H" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="3" Grid.Column="1" Classes="ve-body" Text="{Binding CropHeight}" />
                </Grid>
              </StackPanel>

              <!-- WATERMARK PANEL -->
              <StackPanel Spacing="12"
                          IsVisible="{Binding ActivePanel, Converter={x:Static vm:ToolPanelConverters.IsWatermark}}">
                <TextBlock Classes="ve-section-header" Text="WATERMARK" />
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <CheckBox IsChecked="{Binding IsWatermarkEnabled}" />
                  <TextBlock Classes="ve-body" Text="Enable watermark" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Spacing="8" IsEnabled="{Binding IsWatermarkEnabled}">
                  <TextBlock Classes="ve-section-header" Text="TEXT" />
                  <TextBox Text="{Binding WatermarkText}"
                           Watermark="Watermark text…"
                           Background="{StaticResource VE_SurfaceElevated}"
                           Foreground="{StaticResource VE_Text}"
                           BorderBrush="{StaticResource VE_Border}"
                           CornerRadius="{StaticResource VE_RadiusSM}"
                           Padding="{StaticResource VE_PaddingMD}"
                           FontFamily="{StaticResource VE_FontUI}"
                           FontSize="{StaticResource VE_FontMD}" />
                </StackPanel>
              </StackPanel>

              <!-- EXPORT SETTINGS PANEL -->
              <StackPanel Spacing="12"
                          IsVisible="{Binding ActivePanel, Converter={x:Static vm:ToolPanelConverters.IsExport}}">
                <TextBlock Classes="ve-section-header" Text="EXPORT SETTINGS" />

                <StackPanel Spacing="4">
                  <TextBlock Classes="ve-label" Text="Format" />
                  <ComboBox ItemsSource="{x:Static vm:VideoEditorViewModel.OutputFormats}"
                            SelectedItem="{Binding OutputFormat}"
                            HorizontalAlignment="Stretch"
                            CornerRadius="{StaticResource VE_RadiusSM}" />
                </StackPanel>

                <StackPanel Spacing="4">
                  <TextBlock Classes="ve-label" Text="Frame Rate" />
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Slider Classes="ve-slider"
                            Value="{Binding OutputFps}"
                            Minimum="1" Maximum="60"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True" />
                    <TextBlock Grid.Column="1"
                               Classes="ve-timecode"
                               Text="{Binding OutputFps}"
                               FontSize="{StaticResource VE_FontSM}"
                               Width="30"
                               VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>

                <StackPanel Spacing="4">
                  <TextBlock Classes="ve-label" Text="Quality Scale" />
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Slider Classes="ve-slider"
                            Value="{Binding QualityScale}"
                            Minimum="0.25" Maximum="1" />
                    <TextBlock Grid.Column="1"
                               Classes="ve-timecode"
                               Text="{Binding QualityScale, StringFormat={}{0:P0}}"
                               FontSize="{StaticResource VE_FontSM}"
                               Width="40"
                               VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <CheckBox IsChecked="{Binding MaintainAspectRatio}" />
                  <TextBlock Classes="ve-body" Text="Maintain aspect ratio" VerticalAlignment="Center" />
                </StackPanel>
              </StackPanel>

            </StackPanel>
          </ScrollViewer>

          <!-- Primary export action (always visible) -->
          <Border Grid.Row="2"
                  BorderBrush="{StaticResource VE_Border}"
                  BorderThickness="0 1 0 0"
                  Padding="16 12">
            <Button Classes="ve-primary"
                    Content="Export Video"
                    Command="{Binding ExportCommand}"
                    IsEnabled="{Binding !IsExporting}"
                    HorizontalAlignment="Stretch"
                    ToolTip.Tip="Export the edited video (Ctrl+E)" />
          </Border>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
